# ─── Supabase / Database ──────────────────────────────────────────────────────
# Transaction pooler (port 6543) — used by the API at runtime
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by Alembic migrations only
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-64-char-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-byte base64-encoded key for Fernet encryption of TOTP secrets
MFA_ENCRYPTION_KEY=replace-with-base64-fernet-key
# AES-256 key (32 raw bytes base64-encoded) used to wrap DEKs without a user password
DATA_ENCRYPTION_KEK=replace-with-32-byte-base64-key
# Auth config
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Weaver
APP_VERSION=1.0.0
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
DEBUG=false
COOKIE_SECURE=false

# ─── ML ───────────────────────────────────────────────────────────────────────
MODEL_PATH=app/ml/models/sensitivity_classifier.joblib
